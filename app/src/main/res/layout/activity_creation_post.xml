<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_retour"
            android:theme="@style/Bouton" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGalerie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/btn_galerie"
                android:theme="@style/Bouton" />

            <Button
                android:id="@+id/btnAppareilPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_appareil_photo"
                android:theme="@style/Bouton" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/checkPublique"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/check_publique" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_publier_groupes"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/listGroupes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:choiceMode="multipleChoice" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_description_lieu"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDescriptionLieu"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:drawable/edit_text"
            android:gravity="top"
            android:hint="@string/hint_description_lieu"
            android:inputType="textMultiLine"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_rechercher_tags"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRechercheTag"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/border_fields"
            android:hint="@string/hint_rechercher_tags"
            android:paddingStart="12dp" />

        <ListView
            android:id="@+id/listTagsResultats"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="true"
            android:scrollbars="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_tags_selectionnes"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/listTagsSelectionnes"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:nestedScrollingEnabled="true"
            android:scrollbars="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_description_post"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDescriptionPost"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:drawable/edit_text"
            android:gravity="top"
            android:hint="@string/hint_description_post"
            android:inputType="textMultiLine"
            android:padding="8dp" />

        <Button
            android:id="@+id/btnPublier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/btn_publier"
            android:theme="@style/Bouton" />

    </LinearLayout>
</ScrollView>