<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RETOUR"
            android:theme="@style/Bouton"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnGalerie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Galerie"
                android:layout_marginEnd="8dp"
                android:theme="@style/Bouton"/>

            <Button
                android:id="@+id/btnAppareilPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Appareil photo"
                android:theme="@style/Bouton"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/checkPublique"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rendre la photo publique"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publier dans des groupes"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <ListView
            android:id="@+id/listGroupes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:choiceMode="multipleChoice"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description du lieu"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etDescriptionLieu"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Décrire le lieu, adresse, accès..."
            android:gravity="top"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:inputType="textMultiLine"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Centres d'intérêt"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <ListView
            android:id="@+id/listInterets"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:choiceMode="multipleChoice"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description de la publication"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etDescriptionPost"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Ajouter une description..."
            android:gravity="top"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:inputType="textMultiLine"/>

        <Button
            android:id="@+id/btnPublier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publier"
            android:layout_marginTop="20dp"
            android:theme="@style/Bouton"/>

    </LinearLayout>
</ScrollView>